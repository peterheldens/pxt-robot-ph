<xml xmlns="https://developers.google.com/blockly/xml"><variables></variables><block type="pxt-on-start" x="10" y="10"><statement name="HANDLER"><block type="typescript_statement"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="enum RobotOnderdeel {" line1="    //% block=&quot;antenne&quot;" line2="    Antenne," line3="    //% block=&quot;linker oog&quot;" line4="    LinkerOog," line5="    //% block=&quot;rechter oog&quot;" line6="    RechterOog," line7="    //% block=&quot;ogen&quot;" line8="    Ogen," line9="    //% block=&quot;neus&quot;" line10="    Neus," line11="    //% block=&quot;mond&quot;" line12="    Mond," line13="    //% block=&quot;bovenlip&quot;" line14="    Bovenlip," line15="    //% block=&quot;onderlip&quot;" line16="    Onderlip," line17="    //% block=&quot;hele robot&quot;" line18="    Alles" line19="}" numlines="20"></mutation><next><block type="typescript_statement"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace robot {" line1="" line2="    const LED_PIN = DigitalPin.P16" line3="    const LED_COUNT = 16" line4="" line5="    const ANTENNE = 0" line6="    const LINKER_OOG = 1" line7="    const RECHTER_OOG = 2" line8="    const NEUS = 3" line9="" line10="    const MOND_BEGIN = 4" line11="    const MOND_EIND = 15" line12="" line13="    const BOVENLIP_BEGIN = 4" line14="    const BOVENLIP_EIND = 9" line15="" line16="    const ONDERLIP_BEGIN = 10" line17="    const ONDERLIP_EIND = 15" line18="" line19="    let gezicht: neopixel.Strip = null" line20="" line21="    function initGezicht(): void {" line22="" line23="        if (gezicht) return" line24="" line25="        gezicht = neopixel.create(LED_PIN, LED_COUNT, NeoPixelMode.RGB)" line26="        gezicht.setBrightness(40)" line27="        gezicht.clear()" line28="        gezicht.show()" line29="    }" line30="" line31="    function setKleur(van: number, tot: number, kleur: NeoPixelColors): void {" line32="" line33="        initGezicht()" line34="" line35="        let rgb = neopixel.colors(kleur)" line36="" line37="        for (let i = van; i &lt;= tot; i++) {" line38="            gezicht.setPixelColor(i, rgb)" line39="        }" line40="" line41="        gezicht.show()" line42="    }" line43="" line44="    /**" line45="     * Geef een onderdeel een kleur." line46="     */" line47="    //% blockId=robot_kleur" line48="    //% block=&quot;kleur %onderdeel %kleur&quot;" line49="    //% weight=91" line50="    export function kleur(" line51="        onderdeel: RobotOnderdeel," line52="        kleur: NeoPixelColors" line53="    ): void {" line54="" line55="        switch (onderdeel) {" line56="" line57="            case RobotOnderdeel.Antenne:" line58="                setKleur(ANTENNE, ANTENNE, kleur)" line59="                break" line60="" line61="            case RobotOnderdeel.LinkerOog:" line62="                setKleur(LINKER_OOG, LINKER_OOG, kleur)" line63="                break" line64="" line65="            case RobotOnderdeel.RechterOog:" line66="                setKleur(RECHTER_OOG, RECHTER_OOG, kleur)" line67="                break" line68="" line69="            case RobotOnderdeel.Ogen:" line70="                setKleur(LINKER_OOG, RECHTER_OOG, kleur)" line71="                break" line72="" line73="            case RobotOnderdeel.Neus:" line74="                setKleur(NEUS, NEUS, kleur)" line75="                break" line76="" line77="            case RobotOnderdeel.Mond:" line78="                setKleur(MOND_BEGIN, MOND_EIND, kleur)" line79="                break" line80="" line81="            case RobotOnderdeel.Bovenlip:" line82="                setKleur(BOVENLIP_BEGIN, BOVENLIP_EIND, kleur)" line83="                break" line84="" line85="            case RobotOnderdeel.Onderlip:" line86="                setKleur(ONDERLIP_BEGIN, ONDERLIP_EIND, kleur)" line87="                break" line88="" line89="            case RobotOnderdeel.Alles:" line90="                setKleur(0, LED_COUNT - 1, kleur)" line91="                break" line92="        }" line93="    }" line94="" line95="    /**" line96="     * Wis de robot." line97="     */" line98="    //% blockId=robot_wis" line99="    //% block=&quot;wis&quot;" line100="    //% weight=100" line101="    export function wis(): void {" line102="" line103="        initGezicht()" line104="" line105="        gezicht.clear()" line106="        gezicht.show()" line107="    }" line108="" line109="    /**" line110="     * Stel de helderheid in." line111="     */" line112="    //% blockId=robot_helderheid" line113="    //% block=&quot;helderheid %waarde&quot;" line114="    //% waarde.min=0" line115="    //% waarde.max=255" line116="    //% waarde.defl=40" line117="    //% weight=99" line118="    export function helderheid(waarde: number): void {" line119="" line120="        initGezicht()" line121="" line122="        gezicht.setBrightness(waarde)" line123="        gezicht.show()" line124="    }" line125="" line126="    /**" line127="     * Antenne kleur." line128="     */" line129="    //% blockId=robot_antenne" line130="    //% block=&quot;antenne kleur %kleur&quot;" line131="    //% weight=90" line132="    export function antenneKleur(kleur: NeoPixelColors): void {" line133="        setKleur(ANTENNE, ANTENNE, kleur)" line134="    }" line135="" line136="    /**" line137="     * Linker oog kleur." line138="     */" line139="    //% blockId=robot_linkeroog" line140="    //% block=&quot;linker oog kleur %kleur&quot;" line141="    //% weight=89" line142="    export function linkerOogKleur(kleur: NeoPixelColors): void {" line143="        setKleur(LINKER_OOG, LINKER_OOG, kleur)" line144="    }" line145="" line146="    /**" line147="     * Rechter oog kleur." line148="     */" line149="    //% blockId=robot_rechteroog" line150="    //% block=&quot;rechter oog kleur %kleur&quot;" line151="    //% weight=88" line152="    export function rechterOogKleur(kleur: NeoPixelColors): void {" line153="        setKleur(RECHTER_OOG, RECHTER_OOG, kleur)" line154="    }" line155="" line156="    /**" line157="     * Beide ogen kleur." line158="     */" line159="    //% blockId=robot_ogen" line160="    //% block=&quot;ogen kleur %kleur&quot;" line161="    //% weight=87" line162="    export function ogenKleur(kleur: NeoPixelColors): void {" line163="        setKleur(LINKER_OOG, RECHTER_OOG, kleur)" line164="    }" line165="" line166="    /**" line167="     * Neus kleur." line168="     */" line169="    //% blockId=robot_neus" line170="    //% block=&quot;neus kleur %kleur&quot;" line171="    //% weight=86" line172="    export function neusKleur(kleur: NeoPixelColors): void {" line173="        setKleur(NEUS, NEUS, kleur)" line174="    }" line175="" line176="    /**" line177="     * Mond kleur." line178="     */" line179="    //% blockId=robot_mond" line180="    //% block=&quot;mond kleur %kleur&quot;" line181="    //% weight=85" line182="    export function mondKleur(kleur: NeoPixelColors): void {" line183="        setKleur(MOND_BEGIN, MOND_EIND, kleur)" line184="    }" line185="" line186="    /**" line187="     * Bovenlip kleur." line188="     */" line189="    //% blockId=robot_bovenlip" line190="    //% block=&quot;bovenlip kleur %kleur&quot;" line191="    //% weight=84" line192="    export function bovenlipKleur(kleur: NeoPixelColors): void {" line193="        setKleur(BOVENLIP_BEGIN, BOVENLIP_EIND, kleur)" line194="    }" line195="" line196="    /**" line197="     * Onderlip kleur." line198="     */" line199="    //% blockId=robot_onderlip" line200="    //% block=&quot;onderlip kleur %kleur&quot;" line201="    //% weight=83" line202="    export function onderlipKleur(kleur: NeoPixelColors): void {" line203="        setKleur(ONDERLIP_BEGIN, ONDERLIP_EIND, kleur)" line204="    }" line205="" line206="    /**" line207="     * Hele robot één kleur." line208="     */" line209="    //% blockId=robot_alles" line210="    //% block=&quot;hele robot kleur %kleur&quot;" line211="    //% weight=82" line212="    export function allesKleur(kleur: NeoPixelColors): void {" line213="        setKleur(0, LED_COUNT - 1, kleur)" line214="    }" line215="" line216="}" numlines="217"></mutation></block></next></block></statement></block></xml>